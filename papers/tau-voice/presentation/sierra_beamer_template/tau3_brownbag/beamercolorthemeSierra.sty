%% =============================================================================
%% Sierra Color Theme for Beamer
%% =============================================================================
%% Based on Sierra Template v1.2 from PPTX - "Simple Light" theme
%% =============================================================================

\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{beamercolorthemeSierra}[2024/12/03 Sierra Color Theme]

%% -----------------------------------------------------------------------------
%% Define Sierra Brand Colors (Extracted from PPTX theme1.xml)
%% -----------------------------------------------------------------------------

%% =============================================================================
%% Sierra Brand Color Palette (Official 2025)
%% =============================================================================

% Primary Greens
\definecolor{SierraDarkGreen}{HTML}{05351D}   % Darkest green - title backgrounds
\definecolor{SierraGreen}{HTML}{006838}       % Primary green - links, accents
\definecolor{SierraGreenMid}{HTML}{00913C}    % Mid green
\definecolor{SierraGreenLight}{HTML}{4FAF62}  % Light green
\definecolor{SierraGreenPale}{HTML}{7ED185}   % Pale green
\definecolor{SierraGreenTint}{HTML}{C1F1CB}   % Tint green - charts only

% Neutrals (Core)
\definecolor{SierraCharcoal}{HTML}{302E2D}    % Dark text, titles
\definecolor{SierraBeige}{HTML}{F6F5F3}       % "Bone" background
\definecolor{SierraTaupe}{HTML}{625E5B}       % Body text
\definecolor{SierraLightTaupe}{HTML}{E4E0DC}  % Secondary background

% Gray Scale
\definecolor{SierraGrayDark}{HTML}{898683}    % Mid gray
\definecolor{SierraGray}{HTML}{C1BCB7}        % Muted gray
\definecolor{SierraGrayLight}{HTML}{D5D1CD}   % Light gray
\definecolor{SierraGrayPale}{HTML}{E4E0DC}    % Pale gray

% Oranges
\definecolor{SierraOrangeDark}{HTML}{4F3524}  % Dark orange
\definecolor{SierraOrangeBrown}{HTML}{863D0E} % Brown-orange
\definecolor{SierraOrange}{HTML}{F96205}      % Primary orange - alerts
\definecolor{SierraOrangeMid}{HTML}{EC881B}   % Mid orange
\definecolor{SierraYellow}{HTML}{EBC247}      % Yellow
\definecolor{SierraYellowPale}{HTML}{EBEB98}  % Pale yellow

% Blues
\definecolor{SierraBlueDark}{HTML}{0F3B90}    % Dark blue
\definecolor{SierraBlueMid}{HTML}{1E55C2}     % Mid blue
\definecolor{SierraBlueAccent}{HTML}{126CEB}  % Accent blue
\definecolor{SierraBlue}{HTML}{509EEF}        % Primary blue
\definecolor{SierraBlueLight}{HTML}{8BBFF5}   % Light blue
\definecolor{SierraBluePale}{HTML}{B8D8FA}    % Pale blue

% Purples (Extended)
\definecolor{SierraPurpleDark}{HTML}{483B6A}  % Dark purple
\definecolor{SierraPurple}{HTML}{6953A0}      % Primary purple
\definecolor{SierraPurpleLight}{HTML}{A673DE} % Light purple
\definecolor{SierraPurpleMid}{HTML}{C59DF1}   % Mid purple
\definecolor{SierraPurplePale}{HTML}{D3B3FF}  % Pale purple
\definecolor{SierraPurpleTint}{HTML}{E2CFFD}  % Tint purple

% White
\definecolor{SierraWhite}{HTML}{FFFFFF}       % White

% Aliases for convenience
\colorlet{SierraBone}{SierraBeige}            % "Bone" = Beige background
\colorlet{SierraForest}{SierraDarkGreen}      % "Forest" = Dark green

%% -----------------------------------------------------------------------------
%% Apply Colors to Beamer Elements
%% -----------------------------------------------------------------------------

% Background (warm beige)
\setbeamercolor{background canvas}{bg=SierraBeige}

% Normal Text Colors
\setbeamercolor{normal text}{fg=SierraTaupe}
\setbeamercolor{alerted text}{fg=SierraOrange}
\setbeamercolor{example text}{fg=SierraGreen}

% Title page (dark green background with white text)
\setbeamercolor{title}{fg=SierraWhite,bg=}
\setbeamercolor{subtitle}{fg=SierraWhite}
\setbeamercolor{author}{fg=SierraWhite}
\setbeamercolor{institute}{fg=SierraWhite}
\setbeamercolor{date}{fg=SierraWhite}
\setbeamercolor{title page background}{bg=SierraDarkGreen}

% Frame elements (on light background)
\setbeamercolor{frametitle}{fg=SierraCharcoal,bg=}
\setbeamercolor{framesubtitle}{fg=SierraTaupe}

% Structure elements
\setbeamercolor{structure}{fg=SierraCharcoal}

% Items (Bullets) - use taupe color
\setbeamercolor{itemize item}{fg=SierraTaupe}
\setbeamercolor{itemize subitem}{fg=SierraTaupe}
\setbeamercolor{itemize subsubitem}{fg=SierraTaupe}
\setbeamercolor{enumerate item}{fg=SierraTaupe}
\setbeamercolor{enumerate subitem}{fg=SierraTaupe}

% Blocks - Sierra green header
\setbeamercolor{block title}{fg=SierraWhite,bg=SierraGreen}
\setbeamercolor{block body}{fg=SierraCharcoal,bg=SierraWhite}

% Alert blocks - Sierra orange
\setbeamercolor{block title alerted}{fg=SierraWhite,bg=SierraOrange}
\setbeamercolor{block body alerted}{fg=SierraCharcoal,bg=SierraWhite}

% Example blocks - Sierra Blue (#8BBFF5)
\setbeamercolor{block title example}{fg=SierraWhite,bg=SierraBlueLight}
\setbeamercolor{block body example}{fg=SierraCharcoal,bg=SierraWhite}

% Links
\hypersetup{
  colorlinks=true,
  linkcolor=SierraGreen,
  urlcolor=SierraGreen,
  citecolor=SierraGreen
}

% Footer/Header
\setbeamercolor{footline}{fg=SierraTaupe}
\setbeamercolor{headline}{fg=SierraCharcoal}
\setbeamercolor{page number in head/foot}{fg=SierraTaupe}

% Section/TOC
\setbeamercolor{section in toc}{fg=SierraCharcoal}
\setbeamercolor{subsection in toc}{fg=SierraTaupe}
\setbeamercolor{section in head/foot}{fg=SierraTaupe}

% Separators
\setbeamercolor{separation line}{bg=SierraLightTaupe}

\endinput
