{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "harness-opt/cluster_labels.schema.json",
  "title": "ClusterLabels",
  "type": "object",
  "required": ["contract_version", "run_name", "labels"],
  "properties": {
    "contract_version": { "type": "string", "const": "1.0" },
    "run_name": { "type": "string" },
    "model": { "type": ["string", "null"] },
    "labels": {
      "type": "array",
      "items": { "$ref": "#/$defs/ClusterLabel" }
    }
  },
  "$defs": {
    "ClusterLabel": {
      "type": "object",
      "required": ["cluster_id", "display_name", "cohesion", "blame_tags", "summary"],
      "properties": {
        "cluster_id": { "type": "string" },
        "display_name": { "type": "string" },
        "cohesion": { "type": "number", "minimum": 1, "maximum": 5 },
        "blame_tags": { "type": "array", "items": { "type": "string" } },
        "summary": { "type": "string" },
        "representative_simulation_ids": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    }
  },
  "additionalProperties": false
}
