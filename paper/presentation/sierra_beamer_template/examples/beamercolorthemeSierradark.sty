%% =============================================================================
%% Sierra Dark Color Theme for Beamer
%% =============================================================================
%% Dark variant of Sierra theme - dark green/charcoal backgrounds with light text
%% Based on Sierra Template v1.2 from PowerPoint
%% =============================================================================

\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{beamercolorthemeSierradark}[2024/12/03 Sierra Dark Color Theme]

%% -----------------------------------------------------------------------------
%% Override colors for dark mode
%% -----------------------------------------------------------------------------

% Dark background (using Sierra dark green)
\setbeamercolor{background canvas}{bg=SierraDarkGreen}

% Light text on dark background
\setbeamercolor{normal text}{fg=SierraBeige}
\setbeamercolor{alerted text}{fg=SierraOrange}
\setbeamercolor{example text}{fg=SierraBlue}

% Title page (same dark green, white text)
\setbeamercolor{title}{fg=SierraWhite,bg=}
\setbeamercolor{subtitle}{fg=SierraBeige}
\setbeamercolor{author}{fg=SierraWhite}
\setbeamercolor{institute}{fg=SierraBeige}
\setbeamercolor{date}{fg=SierraBeige}

% Frame elements
\setbeamercolor{frametitle}{fg=SierraWhite,bg=}
\setbeamercolor{framesubtitle}{fg=SierraBeige}

% Structure
\setbeamercolor{structure}{fg=SierraWhite}

% Items (Bullets) - light color
\setbeamercolor{itemize item}{fg=SierraBeige}
\setbeamercolor{itemize subitem}{fg=SierraBeige}
\setbeamercolor{itemize subsubitem}{fg=SierraBeige}
\setbeamercolor{enumerate item}{fg=SierraBeige}
\setbeamercolor{enumerate subitem}{fg=SierraBeige}

% Blocks - keep green header, white body
\setbeamercolor{block title}{fg=SierraWhite,bg=SierraGreen}
\setbeamercolor{block body}{fg=SierraCharcoal,bg=SierraWhite}
\setbeamercolor{block title alerted}{fg=SierraWhite,bg=SierraOrange}
\setbeamercolor{block body alerted}{fg=SierraCharcoal,bg=SierraWhite}
\setbeamercolor{block title example}{fg=SierraWhite,bg=SierraBlueLight}
\setbeamercolor{block body example}{fg=SierraCharcoal,bg=SierraWhite}

% Links
\hypersetup{
  colorlinks=true,
  linkcolor=SierraBlue,
  urlcolor=SierraBlue,
  citecolor=SierraBlue
}

% Footer/Header
\setbeamercolor{footline}{fg=SierraBeige}
\setbeamercolor{headline}{fg=SierraWhite}
\setbeamercolor{page number in head/foot}{fg=SierraBeige}

% Section/TOC
\setbeamercolor{section in toc}{fg=SierraWhite}
\setbeamercolor{subsection in toc}{fg=SierraBeige}

\endinput
